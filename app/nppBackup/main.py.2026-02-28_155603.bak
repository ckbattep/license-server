# main.py
import uvicorn
from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware

from api.verify import router as verify_router

app = FastAPI(
    title="Audit Verification API",
    description="Verify audit hash and signature via HMAC-SHA256",
    version="1.0.0"
)

# CORS (если будет вызов из Android/web)
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],  # в продакшене — укажите конкретные домены
    allow_credentials=True,
    allow_methods=["POST"],
    allow_headers=["*"],
)

# Подключение роутера
app.include_router(verify_router, prefix="/api/v1")

@app.get("/")
def root():
    return {"status": "ok", "service": "audit-verification"}

if __name__ == "__main__":
    uvicorn.run(
        app,
        host="0.0.0.0",
        port=8000,
        log_level="info"
    )
